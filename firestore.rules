rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitives & Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Logic for Admin Verification (based on a dedicated collection)
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 1. News Collection
    match /news/{newsId} {
      allow read: if true; // Public announcements
      allow write: if isAdmin();
    }

    // News Likes
    match /news_likes/{likeId} {
      allow read: if true;
      allow create: if isSignedIn() 
        && incoming().userId == request.auth.uid 
        && incoming().newsId is string;
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow update: if false; 
    }

    // News Comments
    match /news_comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() 
        && incoming().userId == request.auth.uid
        && incoming().newsId is string
        && incoming().textContent is string
        && incoming().textContent.size() <= 1000
        && incoming().userName is string;
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow update: if isAdmin();
    }

    // 2. Reports Collection (BGS)
    match /reports/{reportId} {
      function isValidReport(data) {
        return data.keys().hasAll(['nome', 'cognome', 'codiceFiscale', 'date']) &&
               data.nome is string && data.nome.size() >= 2 &&
               data.codiceFiscale is string && data.codiceFiscale.size() == 16;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidReport(incoming()) && isValidId(reportId);
      allow update: if isAdmin();
      allow delete: if false; // Persistent records
    }

    // 6. Audit Logs
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn(); // System logs action from signed-in users
      allow delete, update: if false; // Immutable logs
    }
  }
}
